# 複製本檔為 config/../.env （放專案根目錄的 .env），填入金鑰後啟動正式模式。
# 切勿將真實 .env 提交到版控。Demo 模式不需要任何金鑰。

# 環境部 環境資料開放平臺  https://data.moenv.gov.tw/paradigm
MOENV_API_KEY=

# 中央氣象署 開放資料平臺  https://opendata.cwa.gov.tw/user/authkey
CWA_AUTH_KEY=

# OpenAQ  https://docs.openaq.org/
OPENAQ_API_KEY=

# WAQI  https://aqicn.org/data-platform/token/
WAQI_TOKEN=

# Sentinel-2 / Copernicus（視接取方式）
SENTINEL_TOKEN=

# Google Maps Platform（Routes / Street View）
GOOGLE_MAPS_KEY=

# ── LLM 解釋層（擇一即可；優先用 Gemini，其次 Anthropic）──
# Google Gemini：到 https://aistudio.google.com/apikey 取得，金鑰以 AIza 開頭
GEMINI_API_KEY=

# Anthropic Claude API  https://docs.anthropic.com/
ANTHROPIC_API_KEY=
